-- Função para desativar cooldowns de ClickDetector (genérico)
local function disableClickDetectorCooldowns()
    for _, cd in pairs(workspace:GetDescendants()) do
        if cd:IsA("ClickDetector") then
            -- Se houver um script que gerencia o cooldown, seria necessário desativá-lo.
            -- Para ClickDetectors simples, o problema geralmente é no script que o usa.
            -- Uma abordagem mais avançada seria hookar o evento MouseClick e dispará-lo repetidamente.
        end
    end
end

